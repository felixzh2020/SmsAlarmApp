<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_primary"
    android:padding="28dp">

    <!-- 闹钟图标（圆形背景 + 应用图标） -->
    <ImageView
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="闹钟图标"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_alarm_icon"
        android:padding="14dp" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvAlarmTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="短信闹钟"
        android:textColor="@color/text_accent"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <!-- 倒计时胶囊 -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="将在 5:00 后自动关闭"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:background="@drawable/bg_countdown_pill"
        android:paddingHorizontal="18dp"
        android:paddingVertical="7dp"
        android:layout_marginBottom="28dp" />

    <!-- 短信信息卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/bg_secondary"
        app:strokeColor="@color/border_primary"
        app:strokeWidth="1dp"
        android:layout_marginBottom="36dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 卡片标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="触发短信"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="14dp" />

            <!-- 发信人 -->
            <TextView
                android:id="@+id/tvSmsSender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="发信人：未知"
                android:textColor="@color/text_accent"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_primary"
                android:layout_marginBottom="10dp" />

            <!-- 消息内容 -->
            <TextView
                android:id="@+id/tvSmsBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:maxLines="8"
                android:ellipsize="end" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 关闭按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDismiss"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:text="关闭闹钟"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="28dp"
        app:elevation="2dp" />

</LinearLayout>
